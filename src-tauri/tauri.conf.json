{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yadm studio",
  "version": "0.1.0",
  "identifier": "dev.yadm.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "yadm studio",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Cross-platform GUI for yadm dotfiles manager",
    "longDescription": "A modern desktop interface to manage your yadm-managed dotfiles: status, commits, alternates, encryption, hooks and bootstrap.",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
